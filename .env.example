# Пример конфигурации для Course CLI
# Скопируйте этот файл в .env и подставьте свои значения

# Настройки для интеграции с хранилищем xAPI (Evidence Locker)
LRS_ENDPOINT=https://lrs.example.com/xapi/statements
LRS_AUTH_TOKEN=your_token_here

# Настройки для матрицы навыков (Skill-matrix)
SKILL_MATRIX_API=https://skills.example.com/api/v1